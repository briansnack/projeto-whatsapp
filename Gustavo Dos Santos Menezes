<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>WhatsApp Assistant</title>
  <style>
    body {
      width: 400px;
      font-family: Arial, sans-serif;
    }
    .function-boxes {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
      padding: 16px;
      border-bottom: 1px solid #e0e0e0;
    }
    .function-box {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 8px;
      background-color: #f0f0f0;
      border-radius: 8px;
      cursor: pointer;
      transition: background-color 0.2s;
    }
    .function-box:hover {
      background-color: #e0e0e0;
    }
    .response-bubbles {
      padding: 16px;
    }
    .response-bubble {
      display: inline-block;
      padding: 8px 16px;
      margin: 4px;
      background-color: #e7f3e7;
      color: #2e7d32;
      border-radius: 16px;
      font-size: 14px;
      cursor: pointer;
      transition: background-color 0.2s;
    }
    .response-bubble:hover {
      background-color: #c8e6c9;
    }
  </style>
</head>
<body>
  <div class="function-boxes">
    <div class="function-box">Settings</div>
    <div class="function-box">Chat</div>
    <div class="function-box">Voice</div>
    <div class="function-box">Timer</div>
    <div class="function-box">AI</div>
  </div>
  <div class="response-bubbles">
    <!-- Response bubbles will be added here dynamically -->
  </div>
  <script src="popup.js"></script>
</body>
</html>
